# FCU Bid Scanner — environment config
# Copy to .env and fill in values

# Output directory for HTML reports
OUTPUT_DIR=./output

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_or_service_key

# PlanetBids vendor account (FCU)
PLANETBIDS_EMAIL=floorcoveringunltd@msn.com
PLANETBIDS_PASSWORD=your_password

# Crisp Plan Room (username, not email)
CRISP_USER=your_crisp_username
CRISP_PASSWORD=your_crisp_password

# BidNet Direct
BIDNET_EMAIL=your_bidnet_email
BIDNET_PASSWORD=your_bidnet_password

# OpenGov procurement portal (Joanne's account)
OPENGOV_EMAIL=your_opengov_email
OPENGOV_PASSWORD=your_opengov_password

# SAM.gov API key — free at https://sam.gov → sign in → Profile → API key
# SAM_GOV_API_KEY=your_key_here

# ---------------------------------------------------------------
# Email notifications — Resend API (https://resend.com)
# ---------------------------------------------------------------

# Resend API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Recipients — comma-separated for multiple
NOTIFY_EMAIL=joanne@fcu.com,lenny@fcu.com

# ---------------------------------------------------------------
# AI Parsing — Ollama (local LLM, optional)
# Run: ollama pull llama3  then: python parser.py --parse-all --ollama
# ---------------------------------------------------------------

# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ---------------------------------------------------------------
# Telegram (optional fallback for cookie-expiry alerts)
# ---------------------------------------------------------------

# NOTIFY_TELEGRAM_TOKEN=your_bot_token
# NOTIFY_TELEGRAM_CHAT_ID=your_chat_id
