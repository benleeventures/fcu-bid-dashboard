# FCU Bid Scanner — environment config
# Copy to .env and fill in values

# ── Storage ───────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# ── Portals ───────────────────────────────────────────────────────────────────
PLANETBIDS_EMAIL=floorcoveringunltd@msn.com
PLANETBIDS_PASSWORD=your_password

BIDNET_EMAIL=your_bidnet_email
BIDNET_PASSWORD=your_bidnet_password

# SAM.gov API key — free at https://sam.gov → sign in → Profile → API key
# DEMO_KEY works at 5 req/hr; get a real key for production
SAM_GOV_API_KEY=DEMO_KEY

# ── AI ────────────────────────────────────────────────────────────────────────
# Dedicated Claude API key for Mac Mini (separate from personal dev account)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local supervisor model — runs on Mac Mini)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Recipients ────────────────────────────────────────────────────────────────
# Joanne — gets: daily digest, job walk CC, compliance alerts, everything
JOANNE_EMAIL=joanne@floorcoveringunlimited.com

# Ben — gets: daily digest (remove BEN_EMAIL line if he steps back)
BEN_EMAIL=ben@floorcoveringunlimited.com

# Lenin (Lenny) — gets: job walk notifications ONLY (one email per bid)
LENIN_EMAIL=lenny@floorcoveringunlimited.com

# Admin (Leo) — gets: supervisor escalation alerts
ADMIN_EMAIL=leo@yourdomain.com

# Legacy fallback — set same as JOANNE_EMAIL
NOTIFY_EMAIL=joanne@floorcoveringunlimited.com

# ── Telegram (optional — cookie-expiry alerts) ────────────────────────────────
# NOTIFY_TELEGRAM_TOKEN=your_bot_token
# NOTIFY_TELEGRAM_CHAT_ID=your_chat_id
